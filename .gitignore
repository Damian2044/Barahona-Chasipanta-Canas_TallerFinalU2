# Caches y bytecode de Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Entornos virtuales
venv/
.venv/
env/
ENV/

# Metadatos de notebooks
.ipynb_checkpoints/

# Ajustes del IDE
.vscode/

# Datos e imagenes pesadas
data/
src/data/
salidas/cudaBin/
salidas/cudaNpy/
salidas/cudaPng/
salidas/npyCpu/
salidas/rawCuda/
src/salidas/cudaBin/
src/salidas/cudaNpy/
src/salidas/cudaPng/
src/salidas/npyCpu/
src/salidas/rawCuda/

# Permitir subir metricas CSV. Los ZIP grandes no se suben a GitHub normal
# porque GitHub bloquea archivos mayores a 100 MB.
!src/metricas/
src/metricas/*
!src/metricas/*.csv
!src/salidas/
src/salidas/*
!src/salidas/*.csv
!src/salidas/paquetes/
src/salidas/paquetes/*
!salidas/
salidas/*
!salidas/*.csv
!salidas/paquetes/
salidas/paquetes/*

# Artefactos locales opcionales
*.log
